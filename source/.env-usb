########################################
# MINI BROKER CONFIG (.env) Version 4.0
# Multi-nodo: Meshtastic Serial + TCP + MeshCore
########################################

############################
# HUB JSONL (GLOBAL)
############################
BROKER_HOST=127.0.0.1
BROKER_PORT=8765

############################
# PUERTO DE CONTROL
############################
BROKER_CTRL_HOST=127.0.0.1
BROKER_CTRL_PORT=8766

############################
# RUNTIME / TIMING (GLOBAL)
############################
BROKER_HEARTBEAT_SEC=15
BROKER_RECONNECT_MIN_SEC=2
BROKER_RECONNECT_MAX_SEC=60
BROKER_SENDQ_MAX=500

############################
# GUARDAS 24/7 (GLOBAL)
############################
BROKER_COOLDOWN_SECS=90
BROKER_FORCE_RECONNECT_GRACE_SEC=2
BROKER_EARLY_DROP_WINDOW=20
BROKER_EARLY_DROP_ESCALATE_TO=180
BROKER_TX_BLOCK_DURING_COOLDOWN=1
BROKER_NO_HEARTBEAT=0

############################
# DATA / LOGS
############################
MINIBROKER_DATA_DIR=/opt/minibroker/data

########################################
# NODOS (configuración multi-nodo)
#
# Tipos soportados:
#   meshtastic_serial  -> USB/PTY local (Meshtastic)
#   meshtastic_tcp     -> API TCP del firmware Meshtastic (WiFi)
#   meshcore_serial    -> MeshCore por puerto serie (USB)
#   meshcore_tcp       -> MeshCore vía red (TCP/WiFi/Ethernet)
#
# Cada nodo es independiente: tiene su propio
# ciclo de reconexión, cooldown y cola de envíos.
# Si un nodo cae, los mensajes se acumulan y se
# reenvían automáticamente al reconectar.
########################################

# ---- Nodo 1: Meshtastic USB local (vía socat PTY) ----
# ---- IMPORTANTE: Si solo va a existir un nodo (da igual el tipo) enumerarlo con NODE_1 -------
# ---- y comentar el resto ------ 

NODE_1_TYPE=meshtastic_serial
NODE_1_ALIAS=local-usb
NODE_1_PORT=/dev/ttyV0
NODE_1_PRIMARY=1

NODE_1_BAUD=115200
NODE_1_USB_LOCK=1
NODE_1_DEAD_SILENCE_SEC=25
NODE_1_LINK_CHECK_SEC=1.0
NODE_1_COOLDOWN_SECS=90

# ---- Nodo 2: Meshtastic TCP remoto (nodo con WiFi) ----
# NODE_2_TYPE=meshtastic_tcp
# NODE_2_ALIAS=remoto-wifi
# NODE_2_PRIMARY=1
# NODE_2_HOST=192.168.1.50
# NODE_2_TCP_PORT=4403
# NODE_2_DEAD_SILENCE_SEC=25
# NODE_2_LINK_CHECK_SEC=1.0
# NODE_2_COOLDOWN_SECS=90
# NODE_2_TCP_DEAD_SILENCE_SEC=60

# ---- Nodo 3: MeshCore serial (nodo independiente) ----
# NODE_3_TYPE=meshcore_serial
# NODE_3_ALIAS=meshcore-zgz
# NODE_3_PRIMARY=1
# NODE_3_PORT=/dev/ttyUSB1
# NODE_3_BAUD=115200
# NODE_3_MC_CHANNEL_MAP=0:chan:0:PUBLIC,2:chan:1:ZGZ
# NODE_3_MC_CHANIDX_TO_CH=0:0,1:2
# NODE_3_MC_CONTACT_TO_CH=abcdef123456:0
# NODE_3_MC_ALIASES=abcdef123456:PEPE
# NODE_3_MC_RX_PREFIX_STYLE=alias
# NODE_3_MC_DEFAULT_CH=0
# NODE_3_MC_SILENCE_RECONNECT_SEC=120
# NODE_3_DEAD_SILENCE_SEC=25
# NODE_3_LINK_CHECK_SEC=1.0
# NODE_3_COOLDOWN_SECS=90

# ---- Nodo 4: MeshCore TCP (nodo MeshCore remoto vía red) ----
# NODE_4_TYPE=meshcore_tcp
# NODE_4_ALIAS=meshcore-remoto
# NODE_4_PRIMARY=1
# NODE_4_MC_TCP_HOST=192.168.1.60
# NODE_4_MC_TCP_PORT=4000
# NODE_4_MC_TCP_DEAD_SILENCE_SEC=60
# NODE_4_MC_CHANNEL_MAP=0:chan:0:PUBLIC
# NODE_4_MC_CHANIDX_TO_CH=0:0
# NODE_4_MC_RX_PREFIX_STYLE=alias
# NODE_4_MC_DEFAULT_CH=0
# NODE_4_MC_SILENCE_RECONNECT_SEC=90
# NODE_4_DEAD_SILENCE_SEC=25
# NODE_4_LINK_CHECK_SEC=1.0
# NODE_4_COOLDOWN_SECS=90

########################################
# ROUTING ENTRE NODOS
#
# OPCIÓN A — Puente automático (recomendado)
# ──────────────────────────────────────────
# NODE_AUTO_BRIDGE=1 genera automáticamente rutas bidireccionales
# entre TODOS los nodos activos (aquellos con NODE_N_TYPE definido).
#
#   1 nodo  →  0 rutas  (sin puente)
#   2 nodos →  2 rutas  (A↔B)
#   3 nodos →  6 rutas  (malla completa A↔B↔C↔A)
#   4 nodos → 12 rutas  (malla completa)
#
# NODE_BRIDGE_CHANNELS: canales broker incluidos (default: 0).
#   Ejemplo multicanal: NODE_BRIDGE_CHANNELS=0,1,2
#
# ⚠ CANALES MESHCORE: NODE_BRIDGE_CHANNELS usa números de canal
#   del broker, NO índices nativos de MeshCore. Si los índices
#   nativos no coinciden con el canal broker deseado, configura:
#     NODE_N_MC_CHANIDX_TO_CH=<idx_mc>:<ch_broker>  (RX)
#     NODE_N_MC_CHANNEL_MAP=<ch_broker>:chan:<idx_mc>:<LABEL>  (TX)
#   Ejemplo: MeshCore canal nativo 1 (ZGZ) ↔ broker canal 0:
#     NODE_3_MC_CHANIDX_TO_CH=1:0
#     NODE_3_MC_CHANNEL_MAP=0:chan:1:ZGZ
#   Sin mapeo: channel_idx nativo = número de canal broker (passthrough).
#
# OPCIÓN B — Rutas manuales
# ──────────────────────────
# Usa NODE_ROUTE_N para topologías asimétricas o cruce de canales.
# Formato: src:alias-origen:canal,dst:alias-destino:canal
# Las reglas manuales y NODE_AUTO_BRIDGE son compatibles:
# las manuales tienen prioridad y no se duplican.
#
# Notas generales:
# - Sin regla activa: el mensaje solo va al hub JSONL.
# - Se evita el eco (mismo nodo origen = destino).
# - Los alias deben coincidir exactamente con NODE_N_ALIAS.
########################################

# --- Puente automático (descomenta para activar) ---
# NODE_AUTO_BRIDGE=1
# NODE_BRIDGE_CHANNELS=0

# --- Rutas manuales (ejemplos para 2, 3 o 4 nodos) ---
# 2 nodos:
# NODE_ROUTE_1=src:local-usb:0,dst:remoto-wifi:0
# NODE_ROUTE_2=src:remoto-wifi:0,dst:local-usb:0
#
# 3 nodos (añade las 4 reglas extra para meshcore-zgz):
# NODE_ROUTE_3=src:meshcore-zgz:0,dst:local-usb:0
# NODE_ROUTE_4=src:meshcore-zgz:0,dst:remoto-wifi:0
# NODE_ROUTE_5=src:local-usb:0,dst:meshcore-zgz:0
# NODE_ROUTE_6=src:remoto-wifi:0,dst:meshcore-zgz:0
#
# 4 nodos (añade las 6 reglas extra para meshcore-remoto):
# NODE_ROUTE_7=src:meshcore-remoto:0,dst:local-usb:0
# NODE_ROUTE_8=src:meshcore-remoto:0,dst:remoto-wifi:0
# NODE_ROUTE_9=src:meshcore-remoto:0,dst:meshcore-zgz:0
# NODE_ROUTE_10=src:local-usb:0,dst:meshcore-remoto:0
# NODE_ROUTE_11=src:remoto-wifi:0,dst:meshcore-remoto:0
# NODE_ROUTE_12=src:meshcore-zgz:0,dst:meshcore-remoto:0

########################################
# COMPATIBILIDAD v2/v3 (UN SOLO NODO)
#
# Si NO se define NODE_1_TYPE, el broker usa
# estas variables para arrancar en modo legacy.
# Útil para instalaciones existentes sin cambios.
########################################

# MESH_CONN_MODE=serial        # serial | tcp
# MESH_USB_PORT=/dev/ttyV0
# MESH_USB_BAUD=115200
# MESH_USB_NO_PROTO=0
# MESH_TCP_HOST=192.168.1.50
# MESH_TCP_PORT=4403
# MESH_TCP_DEAD_SILENCE_SEC=60
# BROKER_USB_LOCK_ENABLE=1
# BROKER_LINK_CHECK_INTERVAL_SEC=1.0
# BROKER_DEAD_LINK_SILENCE_SEC=25

########################################
# APRS CONFIG
########################################

APRS_GATE_ENABLED=1

# KISS (Dire Wolf)
KISS_HOST=127.0.0.1
KISS_PORT=8100

# Indicativo
APRS_CALL=EA2XXX-10

# Ruta APRS
APRS_PATH=WIDE1-1,WIDE2-1

# APRS-IS
APRSIS_USER=EA2XXX
APRSIS_PASSCODE=12345
APRSIS_HOST=rotate.aprs.net
APRSIS_PORT=14580

# Indicativos autorizados separados por comas (vacío = todos)
APRS_ALLOWED_SOURCES=
APRS_EMERGENCY_ALLOWED_CHANNELS=0,1,2

# Control de tráfico
APRS_TX_MIN_INTERVAL_SEC=15

########################################
# APRS INBOUND → MESH (pasarela RF/IS → nodos)
#
# APRS_INBOUND_NODE_ALIASES
#   Alias de los nodos del broker que recibirán los mensajes APRS entrantes.
#   Formato: alias separados por coma, exactamente como NODE_N_ALIAS.
#   Vacío → solo el nodo PRIMARY recibe el mensaje (comportamiento legacy).
#   Ejemplo con 3 nodos:
#     APRS_INBOUND_NODE_ALIASES=local-usb,remoto-wifi,meshcore-zgz
#
# APRS_INBOUND_EMERGENCY_NO_CHTAG
#   Si 1, los mensajes APRS que contengan un prefijo de emergencia reconocido
#   ([EMER], [SOS], [ALERTA] u otros en EMERGENCY_PREFIXES) se inyectan a Mesh
#   aunque no lleven etiqueta [CHx], usando MESHTASTIC_CH como canal destino.
#   Si 0, sin [CHx] el mensaje se descarta (comportamiento original).
########################################
APRS_INBOUND_NODE_ALIASES=local-usb
APRS_INBOUND_EMERGENCY_NO_CHTAG=1
